---
import '@/styles/global.css';
import {
  verifyPassword,
  verifyTOTP,
  generateSessionToken,
  makeSessionCookieHeader,
  checkLoginRateLimit,
  recordLoginFailure,
  SESSION_COOKIE_NAME,
  verifySessionToken,
} from '@/lib/auth';
import { getStringPref } from '@/lib/prefs-db';
import { getCredentials, isValidRpId, getRpId } from '@/lib/passkey';

// If already authenticated, go home
const existingToken = Astro.cookies.get(SESSION_COOKIE_NAME)?.value ?? '';
if (verifySessionToken(existingToken)) {
  return Astro.redirect('/', 302);
}

// Fail-safe: ensure auth is configured
const passwordHash = getStringPref('auth.password_hash');
const totpSecret   = getStringPref('auth.totp_secret');
const unconfigured = !passwordHash || !totpSecret;

// Passkeys: only show if at least one is enrolled AND the RP ID is valid
const passkeys = getCredentials();
const rpId = getRpId(Astro.request.url);
const hasPasskeys = passkeys.length > 0 && isValidRpId(rpId);

const nextParam = new URL(Astro.request.url).searchParams.get('next') ?? '/';

let errorMessage: string | null = null;

if (Astro.request.method === 'POST' && !unconfigured) {
  const ip =
    Astro.request.headers.get('x-forwarded-for')?.split(',')[0]?.trim() ??
    (Astro.clientAddress as string | undefined) ??
    'unknown';

  if (!checkLoginRateLimit(ip)) {
    errorMessage = 'Too many login attempts. Try again in 15 minutes.';
  } else {
    const form = await Astro.request.formData();
    const password  = (form.get('password')  as string | null) ?? '';
    const totpCode  = (form.get('totp_code') as string | null) ?? '';

    // Always evaluate both factors to avoid timing side-channels
    const [passwordOk, totpOk] = await Promise.all([
      verifyPassword(password, passwordHash),
      Promise.resolve(verifyTOTP(totpCode, totpSecret)),
    ]);

    if (passwordOk && totpOk) {
      const token = generateSessionToken();
      const safeDest = nextParam.startsWith('/') && !nextParam.startsWith('//') ? nextParam : '/';
      return new Response(null, {
        status: 302,
        headers: {
          Location: safeDest,
          'Set-Cookie': makeSessionCookieHeader(token),
        },
      });
    } else {
      recordLoginFailure(ip);
      // Artificial delay to slow brute-force before lockout kicks in
      await new Promise((r) => setTimeout(r, 500));
      errorMessage = 'Invalid credentials.';
    }
  }
}
---

<!doctype html>
<html lang="en" class="h-full bg-gray-950">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Mintlayer GUI-X — Sign In</title>
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  </head>

  <body class="h-full flex items-center justify-center text-gray-100 font-sans">
    <div class="w-full max-w-sm px-4">

      <!-- Logo / branding -->
      <div class="flex flex-col items-center mb-8 gap-3">
        <img src="/mintlayer-logo.svg" alt="Mintlayer" class="h-7 brightness-0 invert" />
        <span class="text-mint-400 text-xl font-semibold tracking-tight">Mintlayer GUI-X</span>
        <p class="text-gray-500 text-sm">Sign in to your wallet</p>
      </div>

      {unconfigured && (
        <div class="mb-4 px-4 py-3 rounded-lg border border-amber-800 bg-amber-950/50 text-amber-300 text-sm">
          Authentication is not configured. Run <code class="font-mono">./init.sh</code> to set up a password and 2FA.
        </div>
      )}

      {errorMessage && (
        <div class="mb-4 px-4 py-3 rounded-lg border border-red-800 bg-red-950/50 text-red-300 text-sm">
          {errorMessage}
        </div>
      )}

      <form
        method="post"
        class="bg-gray-900 border border-gray-800 rounded-xl p-6 shadow-xl space-y-4"
      >
        <div>
          <label for="password" class="block text-sm font-medium text-gray-400 mb-1.5">
            Password
          </label>
          <input
            id="password"
            name="password"
            type="password"
            required
            autocomplete="current-password"
            disabled={unconfigured}
            class="w-full px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 text-gray-100
                   placeholder-gray-600 focus:outline-none focus:ring-2 focus:ring-mint-600
                   focus:border-transparent transition disabled:opacity-40 disabled:cursor-not-allowed"
          />
        </div>

        <div>
          <label for="totp_code" class="block text-sm font-medium text-gray-400 mb-1.5">
            Authenticator Code
          </label>
          <input
            id="totp_code"
            name="totp_code"
            type="text"
            required
            inputmode="numeric"
            maxlength="6"
            autocomplete="one-time-code"
            pattern="[0-9]{6}"
            placeholder="000000"
            disabled={unconfigured}
            class="w-full px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 text-gray-100
                   placeholder-gray-600 focus:outline-none focus:ring-2 focus:ring-mint-600
                   focus:border-transparent tracking-[0.4em] text-center font-mono transition
                   disabled:opacity-40 disabled:cursor-not-allowed"
          />
        </div>

        <button
          type="submit"
          disabled={unconfigured}
          class="w-full py-2.5 px-4 rounded-lg bg-mint-600 hover:bg-mint-700 text-white font-medium
                 transition-colors focus:outline-none focus:ring-2 focus:ring-mint-500
                 focus:ring-offset-2 focus:ring-offset-gray-900
                 disabled:opacity-40 disabled:cursor-not-allowed disabled:hover:bg-mint-600"
        >
          Sign in
        </button>
      </form>

      {hasPasskeys && (
        <div class="mt-4">
          <div class="flex items-center gap-3 mb-4">
            <div class="flex-1 h-px bg-gray-800"></div>
            <span class="text-xs text-gray-600">or</span>
            <div class="flex-1 h-px bg-gray-800"></div>
          </div>

          <div id="passkey-error" class="hidden mb-3 px-4 py-3 rounded-lg border border-red-800 bg-red-950/50 text-red-300 text-sm"></div>

          <button
            id="passkey-btn"
            type="button"
            data-next={nextParam}
            class="w-full py-2.5 px-4 rounded-lg bg-gray-800 hover:bg-gray-700 border border-gray-700
                   text-gray-200 font-medium transition-colors focus:outline-none focus:ring-2
                   focus:ring-gray-500 focus:ring-offset-2 focus:ring-offset-gray-950
                   flex items-center justify-center gap-2"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-gray-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/>
            </svg>
            Sign in with a Passkey
          </button>
        </div>
      )}

    </div>
  </body>
</html>

{hasPasskeys && (
  <script>
    import { startAuthentication } from '@simplewebauthn/browser';

    const btn = document.getElementById('passkey-btn') as HTMLButtonElement | null;
    const errorBox = document.getElementById('passkey-error');

    function showError(msg: string) {
      if (!errorBox) return;
      errorBox.textContent = msg;
      errorBox.classList.remove('hidden');
    }

    const passkeyIcon = `<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-gray-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg> Sign in with a Passkey`;

    btn?.addEventListener('click', async () => {
      if (!errorBox || !btn) return;
      errorBox.classList.add('hidden');
      btn.disabled = true;
      btn.textContent = 'Waiting for authenticator…';

      try {
        const optRes = await fetch('/api/passkey/auth-options');
        if (!optRes.ok) {
          const { error } = await optRes.json();
          throw new Error(error ?? 'Failed to load passkey options.');
        }
        const options = await optRes.json();

        const authResponse = await startAuthentication({ optionsJSON: options });

        const verRes = await fetch('/api/passkey/auth-verify', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(authResponse),
        });
        const result = await verRes.json();

        if (!verRes.ok || !result.ok) {
          throw new Error(result.error ?? 'Passkey authentication failed.');
        }

        const nextParam = btn.dataset.next ?? '/';
        const safeDest = nextParam.startsWith('/') && !nextParam.startsWith('//') ? nextParam : '/';
        window.location.href = safeDest;
      } catch (err: unknown) {
        const e = err as { name?: string; message?: string };
        if (e?.name !== 'AbortError') {
          showError(e?.message ?? 'Passkey authentication failed.');
        }
        btn.disabled = false;
        btn.innerHTML = passkeyIcon;
      }
    });
  </script>
)}
