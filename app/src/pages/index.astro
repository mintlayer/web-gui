---
import Layout from '@/layouts/Layout.astro';
import SyncStatus from '@/components/SyncStatus';
import ReceiveModal from '@/components/ReceiveModal';
import {
  getBalance, walletBestBlock, getStakingStatus, listCreatedBlocks,
  nodeChainstateInfo, getTokensInfo, openWallet, isWalletNotOpenError, WalletRpcError,
  type BlockInfo, type ChainstateInfo,
} from '@/lib/wallet-rpc';

const WALLET_PATH = '/home/mintlayer/mintlayer.wallet';

// ── Handle password form POST ─────────────────────────────────────────────────

let passwordError: string | null = null;

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  if (form.get('action') === 'open_with_password') {
    const password = form.get('password')?.toString() || undefined;
    try {
      await openWallet(WALLET_PATH, password);
      // Redirect to GET so a refresh doesn't re-POST
      return new Response(null, { status: 302, headers: { Location: '/' } });
    } catch (err) {
      passwordError = (err as Error).message;
    }
  }
}

// ── Fetch wallet data ─────────────────────────────────────────────────────────

let balance: Awaited<ReturnType<typeof getBalance>> | null = null;
let blockInfo: BlockInfo | null = null;
let chainstate: ChainstateInfo | null = null;
let stakingStatus: string | null = null;
let blocksFound: number | null = null;
let walletError: string | null = null;
let daemonOffline = false;
let needsPassword = false;
let fungibleCount = 0;
let nftCount = 0;

try {
  [balance, blockInfo, stakingStatus, chainstate] = await Promise.all([
    getBalance(0),
    walletBestBlock(),
    getStakingStatus(0),
    nodeChainstateInfo(),
  ]);
  blocksFound = await listCreatedBlocks(0).then(b => b.length).catch(() => null);

  if (balance && Object.keys(balance.tokens).length > 0) {
    const tokenIds = Object.keys(balance.tokens);
    const infos = await Promise.all(
      tokenIds.map(id => getTokensInfo([id]).then(([info]) => info ?? null).catch(() => null))
    );
    for (const info of infos) {
      if (!info) continue;
      if (info.type === 'NonFungibleToken') nftCount++;
      else fungibleCount++;
    }
  }
} catch (err) {
  if (isWalletNotOpenError(err)) {
    // fall through — the client-side opening screen handles it
  } else if (err instanceof WalletRpcError && (err.message.includes('Cannot reach') || err.code === -32000)) {
    daemonOffline = true;
  } else {
    walletError = (err as Error).message;
  }
}

const isStaking = stakingStatus === 'Staking';
const totalTokens = fungibleCount + nftCount;
const indexerEnabled = process.env.INDEXER_ENABLED === 'true';
---

<Layout title="Dashboard" activeNav="dashboard">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-gray-100">Dashboard</h1>
    <ReceiveModal client:load />
  </div>

  <!-- Wallet opening screen (shown client-side when no wallet is open yet) -->
  {!balance && !daemonOffline && !walletError && !needsPassword && (
    <div id="wallet-opening-screen" class="rounded-lg border border-gray-700 bg-gray-900 p-8 mb-6 text-center">
      <div class="inline-block w-6 h-6 border-2 border-mint-500 border-t-transparent rounded-full animate-spin mb-4"></div>
      <p class="text-gray-300 font-medium mb-1">Opening wallet…</p>
      <p id="wallet-opening-msg" class="text-sm text-gray-500">Connecting to mintlayer.wallet</p>
    </div>
  )}

  <!-- Offline banner -->
  {daemonOffline && (
    <div class="rounded-lg border border-yellow-700 bg-yellow-900/30 p-4 mb-6 text-yellow-300 text-sm">
      <strong class="font-semibold">Wallet daemon unreachable.</strong>
      {' '}Check that <code>wallet-rpc-daemon</code> is running.
      <a href="/setup" class="ml-2 underline hover:text-yellow-100">Set up wallet →</a>
    </div>
  )}

  {walletError && !daemonOffline && (
    <div class="rounded-lg border border-red-700 bg-red-900/30 p-4 mb-6 text-red-300 text-sm">
      <strong class="font-semibold">Error:</strong> {walletError}
      <a href="/setup" class="ml-2 underline hover:text-red-100">Open / create wallet →</a>
    </div>
  )}

  <!-- Live sync status -->
  {blockInfo && chainstate && (
    <SyncStatus
      client:load
      initialWalletHeight={blockInfo.height}
      initialNodeHeight={chainstate.best_block_height}
      initialIsSyncing={chainstate.is_initial_block_download}
      indexerEnabled={indexerEnabled}
    />
  )}

  <!-- Stats grid -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
    <div class="rounded-xl bg-gray-900 border border-gray-800 p-5">
      <p class="text-xs text-gray-500 uppercase tracking-wider mb-1">Balance (confirmed)</p>
      {balance ? (
        <p class="text-3xl font-bold text-mint-400 font-mono">
          {balance.coins.decimal}
          <span class="text-base text-gray-400 ml-1">ML</span>
        </p>
      ) : (
        <p class="text-3xl font-bold text-gray-700">—</p>
      )}
      {totalTokens > 0 && (
        <a href="/balances" class="inline-flex items-center gap-1.5 mt-2 text-xs text-gray-500 hover:text-gray-300 transition-colors">
          {fungibleCount > 0 && <span>{fungibleCount} token{fungibleCount !== 1 ? 's' : ''}</span>}
          {fungibleCount > 0 && nftCount > 0 && <span class="text-gray-700">·</span>}
          {nftCount > 0 && <span>{nftCount} NFT{nftCount !== 1 ? 's' : ''}</span>}
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      )}
    </div>

    <div class="rounded-xl bg-gray-900 border border-gray-800 p-5">
      <p class="text-xs text-gray-500 uppercase tracking-wider mb-1">Wallet Block</p>
      {blockInfo ? (
        <p class="text-3xl font-bold text-gray-100 font-mono">#{blockInfo.height.toLocaleString()}</p>
      ) : (
        <p class="text-3xl font-bold text-gray-700">—</p>
      )}
      {chainstate && blockInfo && (
        <p class="text-xs text-gray-500 mt-1">
          Node: <span class="font-mono">#{chainstate.best_block_height.toLocaleString()}</span>
        </p>
      )}
    </div>

    <div class="rounded-xl bg-gray-900 border border-gray-800 p-5">
      <p class="text-xs text-gray-500 uppercase tracking-wider mb-1">Staking (account 0)</p>
      {stakingStatus ? (
        <div class="flex items-center gap-2 mt-1">
          <span class:list={[
            'inline-block w-2.5 h-2.5 rounded-full',
            isStaking ? 'bg-mint-400 animate-pulse' : 'bg-gray-600',
          ]} />
          <span class:list={[
            'text-xl font-semibold',
            isStaking ? 'text-mint-400' : 'text-gray-400',
          ]}>
            {isStaking ? 'Active' : 'Inactive'}
          </span>
        </div>
      ) : (
        <p class="text-xl font-bold text-gray-700 mt-1">—</p>
      )}
    </div>

    <div class="rounded-xl bg-gray-900 border border-gray-800 p-5">
      <p class="text-xs text-gray-500 uppercase tracking-wider mb-1">Blocks Found</p>
      {blocksFound !== null ? (
        <p class="text-3xl font-bold text-gray-100 font-mono">{blocksFound.toLocaleString()}</p>
      ) : (
        <p class="text-3xl font-bold text-gray-700">—</p>
      )}
    </div>
  </div>

  {blockInfo && (
    <div class="rounded-xl bg-gray-900 border border-gray-800 p-5 mb-4">
      <p class="text-xs text-gray-500 uppercase tracking-wider mb-2">Wallet Best Block ID</p>
      <span class="inline-flex items-center gap-1 flex-wrap">
        <span class="font-mono text-xs text-gray-400 break-all">{blockInfo.id}</span>
        <button type="button"
          class="ml-1.5 inline-flex items-center align-middle text-gray-600 hover:text-mint-400 transition-colors shrink-0"
          data-copy-value={blockInfo.id} title="Copy block ID">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="9" y="9" width="13" height="13" rx="2" />
            <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" />
          </svg>
        </button>
      </span>
    </div>
  )}

  {/* ── Password modal — auto-opens when wallet file exists but is encrypted ── */}
  {(needsPassword || passwordError) && (
    <dialog
      id="wallet-password-modal"
      class="rounded-xl bg-gray-900 border border-gray-700 p-0 shadow-2xl backdrop:bg-black/70 max-w-sm w-full"
    >
      <div class="px-6 pt-6 pb-5">
        <div class="flex items-center gap-3 mb-4">
          <svg class="w-5 h-5 text-mint-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
            <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
          </svg>
          <h2 class="text-sm font-semibold text-gray-200">Wallet is locked</h2>
        </div>
        <p class="text-xs text-gray-500 mb-5">Enter your password to unlock the wallet.</p>

        {passwordError && (
          <div class="rounded-lg border border-red-700 bg-red-900/30 px-3 py-2 mb-4 text-red-300 text-xs">
            {passwordError}
          </div>
        )}

        <form method="POST" class="space-y-4">
          <input type="hidden" name="action" value="open_with_password" />
          <div>
            <label for="wallet-password" class="block text-xs text-gray-400 mb-1">Password</label>
            <input
              id="wallet-password"
              name="password"
              type="password"
              required
              autofocus
              placeholder="••••••••"
              class="w-full rounded-lg bg-gray-800 border border-gray-700 text-gray-100 placeholder-gray-600
                     px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-mint-600"
            />
          </div>
          <button
            type="submit"
            class="w-full rounded-lg bg-mint-700 hover:bg-mint-600 px-4 py-2 text-sm font-semibold text-white transition-colors"
          >
            Unlock
          </button>
        </form>
      </div>
    </dialog>
  )}

</Layout>

<script>
  // Auto-open the password modal on page load if rendered
  const modal = document.getElementById('wallet-password-modal') as HTMLDialogElement | null;
  modal?.showModal();

  // If the wallet-opening screen is visible, call the open API then reload
  const openingScreen = document.getElementById('wallet-opening-screen');
  const openingMsg = document.getElementById('wallet-opening-msg');
  if (openingScreen) {
    (async () => {
      try {
        const res = await fetch('/api/wallet-open', { method: 'POST' });
        const data = await res.json() as { ok: boolean; status: string; message?: string };
        if (data.ok) {
          window.location.reload();
        } else if (data.status === 'needs_password') {
          window.location.reload(); // reload so server renders the password modal
        } else if (data.status === 'not_found') {
          window.location.href = '/setup';
        } else {
          if (openingMsg) openingMsg.textContent = data.message ?? 'Failed to open wallet.';
          openingScreen.classList.remove('border-gray-700');
          openingScreen.classList.add('border-red-700', 'bg-red-900/20');
          const spinner = openingScreen.querySelector('.animate-spin') as HTMLElement | null;
          if (spinner) spinner.style.display = 'none';
        }
      } catch {
        if (openingMsg) openingMsg.textContent = 'Could not reach the server.';
      }
    })();
  }
</script>
