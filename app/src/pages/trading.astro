---
import Layout from '@/layouts/Layout.astro';
import OrderBook from '@/components/OrderBook';
import NFTMarketplace from '@/components/NFTMarketplace';
import { listOwnOrders, getBalance, getTokensInfo, isWalletNotOpenError, type OrderInfo } from '@/lib/wallet-rpc';
import { hexToText } from '@/lib/wallet-rpc';
import { INDEXER_START_CMD } from '@/lib/indexer';

let ownOrders: OrderInfo[] = [];
let loadError: string | null = null;
let balanceTokens: { tokenId: string; ticker: string }[] = [];
let ownedNFTs: { tokenId: string; name: string; ticker: string; iconUri: string | null }[] = [];

try {
  const [orders, balance] = await Promise.all([
    listOwnOrders(0),
    getBalance(0),
  ]);
  ownOrders = orders;

  const tokenIds = Object.keys(balance.tokens).filter(
    id => parseFloat(balance.tokens[id].decimal) > 0
  );
  if (tokenIds.length > 0) {
    // node_get_tokens_info does not preserve input order — call one at a time to
    // guarantee the ticker is assigned to the correct token ID.
    const infoResults = await Promise.all(
      tokenIds.map(id => getTokensInfo([id]).then(([info]) => ({ id, info: info ?? null })))
    );

    balanceTokens = infoResults
      .filter(({ info }) => info?.type === 'FungibleToken' || info === null)
      .map(({ id, info }) => {
        let ticker = id.slice(0, 8) + '…';
        if (info?.type === 'FungibleToken') {
          ticker = hexToText(info.content.token_ticker) || ticker;
        }
        return { tokenId: id, ticker };
      });

    ownedNFTs = infoResults
      .filter(({ info }) => info?.type === 'NonFungibleToken')
      .map(({ id, info }) => {
        const meta = (info as Extract<typeof info, { type: 'NonFungibleToken' }>)!.content.metadata;
        return {
          tokenId: id,
          name:    hexToText(meta.name)    || id.slice(0, 8) + '…',
          ticker:  hexToText(meta.ticker)  || '',
          iconUri: meta.icon_uri ? (hexToText(meta.icon_uri) ?? null) : null,
        };
      });
  }
} catch (err) {
  if (isWalletNotOpenError(err)) {
    return new Response(null, { status: 302, headers: { Location: '/' } });
  }
  loadError = (err as Error).message;
}

const initialTokenId = Astro.url.searchParams.get('token') ?? null;
const initialNFTId   = Astro.url.searchParams.get('nft')   ?? null;
const initialTab     = initialNFTId ? 'nft' : 'trading';
---

<Layout title="Trading" activeNav="trading">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-gray-100">Trading</h1>
  </div>

  <div id="indexer-warning" style="display:none"
       class="rounded-lg border border-amber-700 bg-amber-900/20 p-4 mb-6 text-amber-300 text-sm">
    <strong class="block mb-1">Indexer not running</strong>
    Some features (browsing all market orders, filtering by trading pair) require the indexer.
    Start it with:
    <code class="block mt-2 rounded bg-gray-900 px-3 py-1.5 text-xs text-gray-300 font-mono">{INDEXER_START_CMD}</code>
  </div>

  <div id="indexer-syncing" style="display:none"
       class="rounded-lg border border-yellow-700 bg-yellow-900/20 p-4 mb-6 text-yellow-300 text-sm">
    <strong class="block mb-1">Indexer still syncing</strong>
    Some features may not work as expected until the indexer catches up with the chain.
  </div>

  {loadError && (
    <div class="rounded-lg border border-red-700 bg-red-900/30 p-4 mb-6 text-red-300 text-sm">
      <strong>Error loading orders:</strong> {loadError}
    </div>
  )}

  <!-- ── Tab bar ─────────────────────────────────────────────────────────────── -->
  <div class="flex border-b border-gray-800 mb-6">
    <button id="tab-trading" data-tab="trading"
      class:list={["tab-btn px-5 py-2.5 text-sm font-medium border-b-2 transition-colors -mb-px",
        initialTab === 'trading'
          ? "border-mint-500 text-mint-400"
          : "border-transparent text-gray-500 hover:text-gray-300"
      ]}>
      Token Trading
    </button>
    <button id="tab-nft" data-tab="nft"
      class:list={["tab-btn px-5 py-2.5 text-sm font-medium border-b-2 transition-colors -mb-px",
        initialTab === 'nft'
          ? "border-mint-500 text-mint-400"
          : "border-transparent text-gray-500 hover:text-gray-300"
      ]}>
      NFT Marketplace
    </button>
  </div>

  <!-- ── Token Trading panel ────────────────────────────────────────────────── -->
  <div id="panel-trading" style={initialTab === 'nft' ? 'display:none' : ''}>
    <OrderBook client:load initialOwnOrders={ownOrders} balanceTokens={balanceTokens} initialTokenId={initialTokenId} />
  </div>

  <!-- ── NFT Marketplace panel ──────────────────────────────────────────────── -->
  <div id="panel-nft" style={initialTab === 'trading' ? 'display:none' : ''}>
    <NFTMarketplace client:load ownedNFTs={ownedNFTs} initialNFTId={initialNFTId} />
  </div>

</Layout>

<script>
// Indexer status check
fetch('/api/indexer-status')
  .then(r => r.json())
  .then((data: { up: boolean; synced: boolean }) => {
    if (!data.up) {
      const el = document.getElementById('indexer-warning');
      if (el) el.style.display = '';
    } else if (!data.synced) {
      const el = document.getElementById('indexer-syncing');
      if (el) el.style.display = '';
    }
  })
  .catch(() => { /* ignore */ });

// Tab switcher
document.querySelectorAll<HTMLElement>('.tab-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    const tab = btn.dataset.tab;
    document.querySelectorAll<HTMLElement>('.tab-btn').forEach(b => {
      const active = b.dataset.tab === tab;
      b.classList.toggle('border-mint-500', active);
      b.classList.toggle('text-mint-400', active);
      b.classList.toggle('border-transparent', !active);
      b.classList.toggle('text-gray-500', !active);
    });
    const trading = document.getElementById('panel-trading');
    const nft = document.getElementById('panel-nft');
    if (trading) trading.style.display = tab === 'trading' ? '' : 'none';
    if (nft) nft.style.display = tab === 'nft' ? '' : 'none';
  });
});
</script>
