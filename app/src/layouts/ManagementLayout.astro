---
import Layout from '@/layouts/Layout.astro';

export interface Props {
  title: string;
  activeTab: 'wallet' | 'addresses' | 'transactions' | 'utxos' | 'settings';
}

const { title, activeTab } = Astro.props;

const tabs = [
  { href: '/management/wallet',       label: 'Wallet',       key: 'wallet'       },
  { href: '/management/settings',     label: 'Settings',     key: 'settings'     },
  { href: '/management/addresses',    label: 'Addresses',    key: 'addresses'    },
  { href: '/management/transactions', label: 'Transactions', key: 'transactions' },
  { href: '/management/utxos',        label: 'UTXOs',        key: 'utxos'        },
];
---

<Layout title={title} activeNav="management">
  <!-- Management sub-nav -->
  <nav class="flex gap-1 mb-8 border-b border-gray-800 pb-0">
    {tabs.map(({ href, label, key }) => (
      <a
        href={href}
        class:list={[
          'px-4 py-2 text-sm font-medium rounded-t transition-colors -mb-px border-b-2',
          activeTab === key
            ? 'border-mint-500 text-mint-400 bg-gray-900/40'
            : 'border-transparent text-gray-500 hover:text-gray-300 hover:border-gray-600',
        ]}
      >
        {label}
      </a>
    ))}
  </nav>

  <slot />
</Layout>
