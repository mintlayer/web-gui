FROM node:22-alpine

RUN apk add --no-cache python3 make g++ sqlite-dev

WORKDIR /app

# Install deps in a cacheable layer — source is mounted at runtime
COPY package.json package-lock.json ./
RUN npm ci

ENV HOST=0.0.0.0
ENV PORT=4321
EXPOSE 4321

CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
